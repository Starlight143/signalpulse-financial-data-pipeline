# =============================================================================
# SignalPulse Financial Data Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real credentials to version control

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
APP_NAME=signalpulse-financial-data-pipeline
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/signalpulse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# SignalPulse Stage0 Configuration
# -----------------------------------------------------------------------------
# The base URL for the SignalPulse Stage0 API
# Production: https://api.signalpulse.org
# If not set, the system will run in MOCK mode with deterministic responses
STAGE0_BASE_URL=https://api.signalpulse.org

# Your Stage0 API key - obtain from https://signalpulse.org/dashboard
# If not set, MOCK mode is enabled automatically
STAGE0_API_KEY=

# Stage0 request timeout in seconds
STAGE0_TIMEOUT_SECONDS=30

# Enable mock mode explicitly (useful for testing even with API key present)
STAGE0_MOCK_MODE=false

# -----------------------------------------------------------------------------
# Data Ingestion Configuration
# -----------------------------------------------------------------------------
# Binance API Configuration
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RATE_LIMIT_PER_MINUTE=1200

# Bybit API Configuration
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RATE_LIMIT_PER_MINUTE=100

# Ingestion worker settings
INGESTION_INTERVAL_SECONDS=300
INGESTION_RETRY_MAX_ATTEMPTS=3
INGESTION_RETRY_BACKOFF_SECONDS=5
INGESTION_FRESHNESS_THRESHOLD_SECONDS=600

# Supported symbols (comma-separated)
SUPPORTED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT

# -----------------------------------------------------------------------------
# Feature Engineering Configuration
# -----------------------------------------------------------------------------
# Rolling window sizes for feature calculation (in number of data points)
FEATURE_ROLLING_WINDOW_SMALL=10
FEATURE_ROLLING_WINDOW_MEDIUM=50
FEATURE_ROLLING_WINDOW_LARGE=200

# Z-score threshold for anomaly detection
FEATURE_ZSCORE_THRESHOLD=2.0

# Data quality thresholds
FEATURE_MIN_DATA_POINTS=5
FEATURE_MAX_AGE_SECONDS=3600

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS settings (comma-separated origins)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# API key for internal/admin endpoints
INTERNAL_API_KEY=your-internal-api-key-here

# -----------------------------------------------------------------------------
# Alert Configuration
# -----------------------------------------------------------------------------
# Webhook URL for alert delivery (optional)
ALERT_WEBHOOK_URL=

# Alert delivery retry settings
ALERT_RETRY_MAX_ATTEMPTS=3
ALERT_RETRY_BACKOFF_SECONDS=10

# -----------------------------------------------------------------------------
# Idempotency Configuration
# -----------------------------------------------------------------------------
# Idempotency key expiration in seconds (default: 24 hours)
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Observability Configuration
# -----------------------------------------------------------------------------
# Enable structured logging
STRUCTURED_LOGGING=true

# Enable request tracing
REQUEST_TRACING=true

# Health check grace period in seconds
HEALTH_CHECK_GRACE_PERIOD=30